\end{tabular}
\caption{IDPS Deployment Script Inventory}
\end{table}

\subsubsection{Prerequisites and System Requirements}
Before running any script, ensure the following:
\begin{itemize}
 \item \textbf{OS:} Ubuntu 20.04 or 22.04 LTS with \texttt{sudo} or root
access.
 \item \textbf{RAM:} Minimum 4 GB (the master script warns and prompts if RAM
is below 4 GB).
 \item \textbf{Disk:} At least 20 GB free on the root partition.
 \item \textbf{All seven files} listed in Table above must be in the
\textit{same directory}.
 \item \textbf{Internet access} is required for package downloads during
setup.
\end{itemize}

\begin{warningbox}
Do not activate IPS (active blocking) mode until the system has been running in
passive IDS mode for a minimum of two weeks with all false positives tuned out.
Premature blocking can disrupt legitimate reactor control traffic in the PFBR
DDCS network.
\end{warningbox}

\begin{stepbox}{1 --- Run the Master Setup Script}
All scripts must be made executable before running. The master script
\texttt{setup\_script.sh} handles everything from prerequisite checks to
final service verification, and \textbf{is the only script most users
need to run directly}.
\end{stepbox}

\begin{cmdbox}{sudo ./setup\_script.sh}
\begin{lstlisting}[language=bash, caption=Make all scripts executable and launch
master installer]
# Make all scripts executable
chmod +x setup_script.sh siem_setup.sh suricata_setup.sh \
 change_interface.sh change_to_ips.sh change_to_ids.sh
# Run the master setup as root
sudo ./setup_script.sh
\end{lstlisting}
\textbf{What the master script does automatically:}
\begin{enumerate}
 \item Checks for root privileges --- exits with an error if not root.
 \item Verifies prerequisites (\texttt{git}, \texttt{curl}, \texttt{figlet},
\texttt{lolcat}) and installs any that are missing.
 \item Displays a welcome banner via \texttt{figlet} and checks total system
RAM, warning if it is below 4~GB.
 \item Prompts: \textit{``Do you want to install the SIEM?''} --- if yes,
calls \texttt{siem\_setup.sh}.
 \item Prompts: \textit{``Do you want to install Suricata?''} --- if yes,
calls \texttt{suricata\_setup.sh}.
\end{enumerate}
\end{cmdbox}

\begin{notebox}
No prior Linux experience is required for this step. If a prompt shows
\texttt{(y/n)}, type \texttt{y} for yes or \texttt{n} for no and press
\textbf{Enter}. If \texttt{sudo} asks for a password, nothing will appear on
screen as you type it --- this is normal.
\end{notebox}

\begin{stepbox}{2 --- SIEM Setup (\texttt{siem\_setup.sh})}
When the master script calls \texttt{siem\_setup.sh}, the following happens
automatically. \textbf{The only manual inputs required} are:
\begin{itemize}
 \item Setting passwords for Elasticsearch built-in users when prompted by
 \texttt{elasticsearch-setup-passwords interactive}.
 \item Re-entering the \texttt{elastic} user password when Kibana and Filebeat
 configurations ask for it.
\end{itemize}
\end{stepbox}

\begin{cmdbox}{siem\_setup.sh internals}
\begin{lstlisting}[language=bash, caption=What siem\_setup.sh does internally]
# 1. Checks for and removes any conflicting existing ELK installations
# 2. Adds the Elastic 7.x GPG key and repository
# 3. Installs Elasticsearch 7.17.13, Kibana 7.17.13, Filebeat 7.17.13
# 4. Generates mutual TLS certificates for all three components using
#    elasticsearch-certutil and distributes them to:
#    /etc/elasticsearch/certs/
#    /etc/filebeat/certs/
#    /etc/kibana/certs/
# 5. Writes elasticsearch.yml with xpack.security enabled + TLS paths
# 6. Writes kibana.yml with HTTPS + elastic credentials
# 7. Writes filebeat.yml with HTTPS output + TLS verification
# 8. Starts and enables all three services
# 9. Runs: filebeat setup -e (loads dashboards and index templates)
\end{lstlisting}
\end{cmdbox}

\begin{warningbox}
\textbf{Write your password down.} Partway through this stage, the
\texttt{elasticsearch-setup-passwords interactive} tool asks you to create
passwords for several built-in accounts --- the most important is
\texttt{elastic}. Record it somewhere safe: you will be asked to re-enter it
moments later, and you will need it every time you log in to the dashboard.
\end{warningbox}

\begin{notebox}
After \texttt{siem\_setup.sh} completes, Kibana is accessible at
\texttt{https://<SERVER\_IP>:5601}. Log in with the \texttt{elastic}
password you set during the \texttt{elasticsearch-setup-passwords interactive}
step.
\end{notebox}

\begin{stepbox}{3 --- Suricata Setup (\texttt{suricata\_setup.sh})}
When the master script calls \texttt{suricata\_setup.sh}, the following happens.
\textbf{The only manual input required} is entering your active network
interface
name when prompted (e.g., \texttt{eth0}, \texttt{enp0s3}, \texttt{ens33}). If
you
do not know it, open a second terminal and run \texttt{ip a} --- the interface
carrying your machine's IP address (usually starting \texttt{en...} or
\texttt{eth...}) is normally the one you want.
\end{stepbox}

\begin{cmdbox}{suricata\_setup.sh internals}
\begin{lstlisting}[language=bash, caption=Suricata setup flow]
# 1. Creates the 'suricata' system user if it does not exist
# 2. Removes any prior Suricata installation (with your confirmation)
# 3. Installs all build dependencies (libpcap, libnet, libyaml, etc.)
# 4. Adds the OISF PPA and installs suricata
# 5. Prompts: "Enter the active network interface name:"
#    --> Type your interface name (e.g. enp3s0) and press Enter
# 6. Updates /etc/default/suricata with IFACE=<your_interface>
# 7. Applies suricata_temp.yaml as /etc/suricata/suricata.yaml
#    (This template has EVE JSON, all protocol parsers,
#     ICS groups: Modbus/DNP3/ENIP, and community-id enabled)
# 8. Enables seven rule sources via suricata-update:
#    oisf/trafficid, etnetera/aggressive,
#    sslbl/ssl-fp-blacklist, et/open, tgreen/hunting,
#    sslbl/ja3-fingerprints, ptresearch/attackdetection
# 9. Restarts Suricata and waits for "Engine started" in the log
# 10. Enables the Filebeat suricata module and restarts Filebeat
\end{lstlisting}
\end{cmdbox}

\begin{notebox}
After setup, verify Suricata is running and writing EVE JSON:
\begin{lstlisting}[language=bash]
sudo systemctl status suricata
sudo tail -f /var/log/suricata/eve.json
\end{lstlisting}
The word \texttt{active (running)} in the status output means the service is
healthy.
\end{notebox}

\begin{stepbox}{4 --- Change the Monitored Interface
(\texttt{change\_interface.sh})}
If the monitored network interface needs to be changed after installation
(e.g., after connecting to a new SPAN port), no reinstallation is required.
\end{stepbox}

\begin{cmdbox}{sudo ./change\_interface.sh}
\begin{lstlisting}[language=bash, caption=Change the monitored network
interface]
sudo ./change_interface.sh
# Prompts: "Enter the new network interface name (e.g., eth0, ens33):"
# --> The script updates all "interface:" entries in suricata.yaml
#     and automatically restarts Suricata.
\end{lstlisting}
\textbf{What the script does internally:}
\begin{itemize}
 \item Uses \texttt{grep -oP} to read the current interface from
\texttt{suricata.yaml}.
 \item Uses \texttt{sed -i} to replace all occurrences of the old interface
name with the new one.
 \item Calls \texttt{systemctl restart suricata} and verifies the service
came back up.
\end{itemize}
\end{cmdbox}

\begin{stepbox}{5 --- Switching Between IDS and IPS Mode}
The system ships in \textbf{passive IDS mode} (monitoring only, no blocking).
Two scripts control the mode transition; run them only when you are confident
in what each does, as described below.
\end{stepbox}

\paragraph{Activating IPS Mode (\texttt{change\_to\_ips.sh})}
Run this script only after the system has been operating in IDS mode for at
least two weeks with all false positives resolved:

\begin{cmdbox}{sudo ./change\_to\_ips.sh}
\begin{lstlisting}[language=bash, caption=Switch to active IPS mode]
sudo ./change_to_ips.sh
\end{lstlisting}
\textbf{What the script does:}
\begin{enumerate}
 \item \textbf{Flushes all existing iptables rules} and resets counters
(\texttt{iptables -F}, \texttt{-X}, \texttt{-Z}).
 \item Sets \textbf{default DROP} policies on INPUT and FORWARD chains---all
traffic is blocked unless explicitly allowed.
 \item Allows loopback traffic (\texttt{-i lo}) so Elasticsearch, Kibana, and
Filebeat can communicate locally.
 \item Allows established and related connections (\texttt{--ctstate
ESTABLISHED,RELATED}) so existing sessions are not disrupted.
 \item Allows incoming SSH on port 22 to prevent administrator lockout.
 \item Configures \textbf{Elasticsearch heap size to 16 GB} by writing to \\
\texttt{/etc/elasticsearch/jvm.options.d/99-heap-size-override.conf}.
 \item Saves iptables rules permanently using \texttt{netfilter-persistent
save} if \texttt{iptables-persistent} is installed.
\end{enumerate}
\end{cmdbox}

\begin{warningbox}
\texttt{change\_to\_ips.sh} flushes ALL iptables rules before applying new ones.
Ensure SSH is accessible before running this on a remote server, or you risk
being locked out.
\end{warningbox}

\paragraph{Reverting to IDS Mode (\texttt{change\_to\_ids.sh})}
To switch back to passive monitoring at any time:

\begin{cmdbox}{sudo ./change\_to\_ids.sh}
\begin{lstlisting}[language=bash, caption=Revert to passive IDS mode]
sudo ./change_to_ids.sh
\end{lstlisting}
\textbf{What the script does:}
\begin{enumerate}
 \item Removes the IPS systemd override file \\
(\texttt{/etc/systemd/system/suricata.service.d/99-ips-mode.conf}).
 \item \textbf{Flushes all iptables rules} and resets default policies to
ACCEPT---traffic flows freely again.
 \item Reloads the systemd daemon and restarts Suricata in default IDS mode.
 \item Prints the live service status for immediate verification.
\end{enumerate}
\end{cmdbox}

\begin{stepbox}{6 --- Verify the Complete Pipeline}
After both \texttt{siem\_setup.sh} and \texttt{suricata\_setup.sh} complete,
run the checks below to confirm the full data pipeline --- from packet capture
to dashboard --- is operational end to end.
\end{stepbox}

\begin{cmdbox}{Full pipeline verification}
\begin{lstlisting}[language=bash, caption=Full pipeline verification commands]
# 1. Confirm Suricata is running and writing EVE JSON
sudo systemctl status suricata
sudo tail -f /var/log/suricata/eve.json
# 2. Confirm Filebeat is running with no errors
sudo systemctl status filebeat
sudo journalctl -u filebeat -n 50 --no-pager
# 3. Confirm Elasticsearch cluster is healthy
curl -sk -u elastic:<PASSWORD> \
  https://localhost:9200/_cluster/health?pretty
# 4. Open Kibana at https://<SERVER_IP>:5601
#     Navigate: Discover -> filebeat-* index -> Last 15 minutes
#     New Suricata alert documents should appear in near real-time.
\end{lstlisting}
\end{cmdbox}

\begin{notebox}
If Filebeat cannot read \texttt{eve.json} due to a permission error, fix with:
\begin{lstlisting}[language=bash]
sudo usermod -aG suricata filebeat
sudo systemctl restart filebeat
\end{lstlisting}
\end{notebox}

