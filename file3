\hline
\texttt{SHUTDOWN} & SHUTDOWN & Complete service denial \\ \hline
\texttt{FLUSH PRIVILEGES} & RELOAD & Reloads modified user table \\ \hline
\texttt{CREATE USER / GRANT ALL} & CREATE USER + GRANT OPTION & Persistent
backdoor \\ \hline
\texttt{LOAD DATA INFILE} & FILE & Arbitrary OS file read/write \\ \hline
\texttt{INSTALL PLUGIN} & PLUGIN\_ADMIN & Load arbitrary shared libraries \\
\hline
\end{tabular}
\caption{High-Risk MySQL Administrative Commands}
\end{table}

\subsection{MySQL Security Hardening: Step-by-Step Setup Guide}
\begin{stepbox}{1 --- Install MySQL and Run Secure Installation}
\begin{lstlisting}[language=bash, caption=MySQL Installation]
sudo apt update && sudo apt install mysql-server -y
sudo mysql_secure_installation
\end{lstlisting}
\begin{notebox}
\texttt{mysql\_secure\_installation} removes anonymous users, disables remote
root login, removes the test database, and reloads privilege tables. Answer
\textbf{Yes} to all prompts.
\end{notebox}
\end{stepbox}

\begin{stepbox}{2 --- Restrict Network Binding to Localhost}
Edit \texttt{/etc/mysql/mysql.conf.d/mysqld.cnf} and set:
\begin{lstlisting}[caption=Bind Address Setting]
bind-address = 127.0.0.1
\end{lstlisting}
\begin{lstlisting}[language=bash, caption=Apply the Change]
sudo systemctl restart mysql
\end{lstlisting}
\begin{notebox}
This eliminates the public port 3306 exposure vector. If remote admin access is
needed, use an SSH tunnel---never expose 3306 directly.
\end{notebox}
\end{stepbox}

\begin{stepbox}{3 --- Enable SSL/TLS Encryption}
\begin{lstlisting}[language=bash, caption=Generate SSL/TLS Certificates]
sudo mysql_ssl_rsa_setup --uid=mysql
\end{lstlisting}
Add to \texttt{mysqld.cnf}:
\begin{lstlisting}[caption=Enforce Secure Transport]
require_secure_transport = ON
\end{lstlisting}
Verify after restarting:
\begin{lstlisting}[language=bash, caption=Verify SSL Cipher]
mysql -u root -p -e "SHOW STATUS LIKE 'Ssl_cipher';"
\end{lstlisting}
\end{stepbox}

\begin{stepbox}{4 --- Enforce Strong Password Policy}
\begin{lstlisting}[style=sqlstyle, caption=Install and Configure Password
Policy]
INSTALL COMPONENT 'file://component_validate_password';
SET GLOBAL validate_password.policy = STRONG;
SET GLOBAL validate_password.length = 12;
SET GLOBAL validate_password.mixed_case_count = 1;
SET GLOBAL validate_password.number_count = 1;
SET GLOBAL validate_password.special_char_count = 1;
\end{lstlisting}
\end{stepbox}

\begin{stepbox}{5 --- Apply the Principle of Least Privilege}
\begin{lstlisting}[style=sqlstyle, caption=Create Least-Privilege Application
User]
CREATE USER 'ddcs_app'@'localhost'
 IDENTIFIED BY 'StrongP@ss2024!';
GRANT SELECT, INSERT, UPDATE ON pfbr_db.* TO 'ddcs_app'@'localhost';
FLUSH PRIVILEGES;
\end{lstlisting}
Audit permissions quarterly:
\begin{lstlisting}[style=sqlstyle, caption=Audit User Privileges]
SELECT * FROM information_schema.USER_PRIVILEGES;
\end{lstlisting}
\begin{warningbox}
Never grant \texttt{ALL PRIVILEGES}, \texttt{FILE}, or \texttt{SUPER} to
application-tier users. These enable full server compromise via privilege
escalation chains.
\end{warningbox}
\end{stepbox}

\begin{stepbox}{6 --- Enable Comprehensive Audit Logging}
\begin{lstlisting}[style=sqlstyle, caption=Enable Audit Logging]
INSTALL PLUGIN audit_log SONAME 'audit_log.so';
SET GLOBAL audit_log_policy = ALL;
SET GLOBAL audit_log_format = JSON;
SET GLOBAL audit_log_file = '/var/log/mysql/audit.json';
\end{lstlisting}
\end{stepbox}

\begin{stepbox}{7 --- Configure Firewall Rules}
\begin{lstlisting}[language=bash, caption=Firewall Configuration]
sudo ufw deny 3306
sudo ufw allow from 192.168.1.0/24 to any port 3306
sudo ufw reload && sudo ufw status verbose
\end{lstlisting}
\begin{notebox}
Replace \texttt{192.168.1.0/24} with the actual CIDR of the DDCS management
network.
\end{notebox}
\end{stepbox}

\begin{stepbox}{8 --- Schedule Regular Security Patch Updates}
\begin{lstlisting}[language=bash, caption=MySQL Update Process]
sudo apt-mark hold mysql-server    # Hold during testing
sudo apt-mark unhold mysql-server # Release after validation
sudo apt-get update && sudo apt-get upgrade mysql-server -y
mysql --version                    # Verify new version
\end{lstlisting}
MySQL 8.4 LTS receives quarterly Critical Patch Updates (CPUs). Maintain a patch
deployment SLA of 7 days for critical CVEs.
\end{stepbox}

